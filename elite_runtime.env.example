# Elite API runtime environment template
#
# Usage — Linux/macOS:
#   cp elite_runtime.env.example .env
#   export $(grep -v '^#' .env | xargs)
#   python -m uvicorn elite_api:app --host $ELITE_API_HOST --port $ELITE_API_PORT
#
# Usage — PowerShell (Windows):
#   Get-Content elite_runtime.env.example | Where-Object { $_ -notmatch '^#' } |
#     ForEach-Object { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v) }
#   python -m uvicorn elite_api:app --host $env:ELITE_API_HOST --port $env:ELITE_API_PORT
#
# Usage — Docker:
#   docker run --env-file .env -p 8877:8877 senia-elite-color
#
# Unset variables fall back to sensible defaults relative to the working directory.
# On production, override ELITE_OUTPUT_ROOT / DB paths to persistent volumes.

ELITE_API_HOST=0.0.0.0
ELITE_API_PORT=8877
ELITE_LOG_LEVEL=info

# Paths — use forward slashes on all platforms; defaults resolve relative to project root
# Linux/macOS example:
ELITE_OUTPUT_ROOT=./service_runs
ELITE_HISTORY_DB=./quality_history.sqlite
ELITE_INNOVATION_DB=./innovation_state.sqlite
# Windows example (uncomment and adjust):
# ELITE_OUTPUT_ROOT=C:/color/service_runs
# ELITE_HISTORY_DB=C:/color/quality_history.sqlite
# ELITE_INNOVATION_DB=C:/color/innovation_state.sqlite

ELITE_ACCEPTANCE_SYNC_TTL_SEC=20
ELITE_ENABLE_AUDIT_LOG=true
ELITE_AUDIT_LOG_PATH=./logs/elite_audit.jsonl
ELITE_METRICS_WINDOW_SIZE=4000

# API key authentication (disabled by default for local dev)
ELITE_ENABLE_API_KEY_AUTH=false
# format A: {"viewer":"viewer-key","operator":"operator-key","admin":"admin-key"}
# format B: {"viewer-key":"viewer","operator-key":"operator","admin-key":"admin"}
ELITE_API_KEYS_JSON={"viewer":"change-me-viewer","operator":"change-me-operator","admin":"change-me-admin"}
ELITE_AUTH_HEADER_NAME=x-api-key

# Rate limiting (0 = unlimited)
ELITE_RATE_LIMIT_RPM=0

# Multi-tenancy (disabled by default)
ELITE_ENFORCE_TENANT_HEADER=false
ELITE_TENANT_HEADER_NAME=x-tenant-id
ELITE_ALLOWED_TENANTS=tenant-a,tenant-b

# Alerting
ELITE_ALERT_WEBHOOK_URL=
ELITE_ALERT_WEBHOOK_MAP_JSON=
# webhook | wecom | dingtalk
ELITE_ALERT_PROVIDER=webhook
# Required when ELITE_ALERT_PROVIDER=dingtalk
ELITE_ALERT_DINGTALK_SECRET=
ELITE_ALERT_TIMEOUT_SEC=4
ELITE_ALERT_MIN_LEVEL=error
ELITE_ALERT_COOLDOWN_SEC=90
ELITE_ALERT_RETRY_COUNT=2
ELITE_ALERT_RETRY_BACKOFF_MS=500
ELITE_ALERT_DEAD_LETTER_PATH=./logs/elite_alert_dead_letter.jsonl
ELITE_ALERT_DEAD_LETTER_MAX_MB=20
ELITE_ALERT_DEAD_LETTER_BACKUPS=5

# Security & audit rotation
ELITE_ENABLE_SECURITY_HEADERS=true
ELITE_AUDIT_ROTATE_MAX_MB=50
ELITE_AUDIT_ROTATE_BACKUPS=5
ELITE_METRICS_MAX_PATH_ENTRIES=3000
ELITE_OPS_SUMMARY_CACHE_TTL_SEC=15
